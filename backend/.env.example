GOOGLE_API_KEY=your_gemini_api_key_here
# Comma-separated list of allowed origins. You will set this in Render to point to your Vercel URL.
CORS_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:5173

# Optional: Password to bypass API rate limits on the frontend.
ADMIN_SECRET=my_super_secret_password_123

# Rate Limits
DAILY_GLOBAL_LIMIT=18
DAILY_IP_LIMIT=3
